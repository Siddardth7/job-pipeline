{
  "manifest_version": 3,
  "name": "JobAgent Auto-Apply",
  "version": "1.0.0",
  "description": "Auto-fill job applications from your JobAgent pipeline",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://wefcbqfxzvvgremxhubi.supabase.co/*",
    "https://resume-compiler-1077806152183.us-central1.run.app/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "JobAgent Auto-Apply"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.lever.co/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
